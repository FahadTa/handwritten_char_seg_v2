# =============================================================================
# Handwritten Character Segmentation v2 - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
conda-env/

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Generated Data (large, regenerable)
# -----------------------------------------------------------------------------
data/
!data/.gitkeep

# -----------------------------------------------------------------------------
# Model Checkpoints (large binary files)
# -----------------------------------------------------------------------------
outputs/checkpoints/
outputs/checkpoints_unet/
outputs/checkpoints_swin/
*.ckpt

# -----------------------------------------------------------------------------
# Evaluation Outputs (regenerable from checkpoints)
# -----------------------------------------------------------------------------
outputs/evaluation/

# -----------------------------------------------------------------------------
# W&B
# -----------------------------------------------------------------------------
wandb/
outputs/wandb/
outputs/*/wandb/

# -----------------------------------------------------------------------------
# Fonts (large binary files, download separately)
# -----------------------------------------------------------------------------
fonts/*.ttf
fonts/*.otf
!fonts/.gitkeep

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
lightning_logs/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pkl
*.pickle
*.npy
*.npz
*.h5
*.hdf5
*.tar
*.tar.gz
*.zip